# Disjorn server configuration — copy to server/.env and edit.
#
#   cp deploy/.env.example server/.env
#
# Every variable here maps 1:1 to server/app/config.py (pydantic-settings).
# Relative paths resolve against the process working directory, which is
# server/ both under systemd (WorkingDirectory=) and when run by hand from
# server/. Lines commented out show the built-in default.

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# SQLite database file (WAL mode; -wal/-shm siblings appear next to it).
#DB_PATH=data/disjorn.db

# Runtime data root: uploads/, assets/picker/, assets/chibi_packs/ live here.
#DATA_DIR=data

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# HMAC signing key for signed media URLs etc. REQUIRED in production —
# the "dev-secret-change-me" default is not safe. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-see-comment-above

# Set true when serving over HTTPS (e.g. behind `tailscale serve`) so the
# session cookie is marked Secure. Leave false for plain-HTTP tailnet use.
COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# Web Push (VAPID)
# ---------------------------------------------------------------------------
# Generate a keypair once and paste the two lines it prints:
#   cd server && .venv/bin/python cli.py gen-vapid
# Leaving these empty disables Web Push (the API returns 503 for push ops).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact claim sent to push services — use a real mailto: you own.
VAPID_CLAIMS_EMAIL=mailto:admin@example.com

# ---------------------------------------------------------------------------
# Media & uploads
# ---------------------------------------------------------------------------
# Max upload size in bytes (default 200 MiB — generous, trusted users).
#MAX_UPLOAD_BYTES=209715200

# Seconds a signed media URL stays valid.
#MEDIA_URL_TTL=3600

# ---------------------------------------------------------------------------
# Pluggable services
# ---------------------------------------------------------------------------
# Ollama endpoint + model used for link summarization.
#OLLAMA_URL=http://localhost:11434
#OLLAMA_MODEL=llama3.2

# Speech-to-text: engine key (services.stt.ENGINES) and whisper model size
# (tiny/base/small/medium/large-v3 — bigger = better + slower; needs the
# requirements-ml.txt extras installed, ideally with a GPU).
#STT_ENGINE=faster_whisper
#STT_MODEL=small

# Summarizer engine key (services.summarize.ENGINES).
#SUMMARIZE_ENGINE=ollama
